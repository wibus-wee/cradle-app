# ─── Cradle Server ───────────────────────────────────────────
CRADLE_DATA_DIR=./data
CRADLE_CREDENTIAL_SECRET=change-me-server-secret

# ─── Langfuse (LLM Observability) ───────────────────────────
# Self-host: docker compose up — or use cloud.langfuse.com (free tier)
# Langfuse is an optional exporter for Cradle's OpenTelemetry spans.
CRADLE_LANGFUSE_ENABLED=0
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── OpenTelemetry / Runtime Observability ──────────────────
# Enable standard traces and metrics. Use an OTLP Collector, Grafana Alloy,
# or any backend that accepts OTLP HTTP on port 4318.
CRADLE_OTEL_ENABLED=0
CRADLE_OTEL_SERVICE_NAME=cradle-server
CRADLE_OTEL_ENV=development
CRADLE_OTEL_TRACES_ENABLED=1
CRADLE_OTEL_METRICS_ENABLED=1
CRADLE_OTEL_LOG_CORRELATION_ENABLED=1
CRADLE_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
CRADLE_OTEL_RUNTIME_SAMPLE_INTERVAL_MS=10000

# ─── Anonymous Product Analytics (PostHog) ──────────────────
# The renderer only sends manually defined semantic events. DOM autocapture,
# session replay, exception capture, prompts, code, paths, and resource IDs are disabled.
# Desktop releases inject these from the repository secret POSTHOG_PROJECT_TOKEN
# (see .github/workflows/release-desktop.yml). Local `pnpm dev` reads this file.
VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_BUILD_CHANNEL=
# Set for internal builds/devices so they remain visible but do not inflate external usage.
VITE_POSTHOG_AUDIENCE=
VITE_POSTHOG_INTERNAL_ACTOR=

# ─── Internal AI Observability (PostHog via OpenTelemetry) ──
# Server-side AI traces for development and internal dogfooding. `metadata`
# sends model, latency, token/cache counts, and cost without conversation content.
# `full` also sends prompts, outputs, and tool names/inputs/outputs.
# Keep full capture disabled in end-user builds until explicit server-side consent exists.
# Packaged `dev` / `bleeding-edge` builds bake these when POSTHOG_AI is enabled in CI;
# `release` channel keeps AI observability off and only ships product analytics.
CRADLE_POSTHOG_AI_OBSERVABILITY_ENABLED=0
CRADLE_POSTHOG_AI_CAPTURE_MODE=metadata
CRADLE_POSTHOG_PROJECT_TOKEN=
CRADLE_POSTHOG_HOST=https://us.i.posthog.com

# Optional local Prometheus scrape endpoint served by the server process.
CRADLE_OTEL_PROMETHEUS_ENABLED=0
CRADLE_OTEL_PROMETHEUS_HOST=127.0.0.1
CRADLE_OTEL_PROMETHEUS_PORT=9464
CRADLE_OTEL_PROMETHEUS_ENDPOINT=/metrics

# Guarded diagnostics for local leak investigation. Disabled by default because
# heap snapshots pause the process and can temporarily require much more memory.
CRADLE_DIAGNOSTICS_ENABLED=0
