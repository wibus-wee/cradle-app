{
  "name": "@cradle/codex-plus-plus",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "cradle": {
    "apiVersion": "1",
    "displayName": "Codex++",
    "description": "Mirrors Codex++ relay profiles through Cradle external provider sources",
    "server": "dist/server.mjs",
    "deployments": ["desktop"],
    "contributes": {
      "capabilities": [
        {
          "id": "external-provider-source.codex-plus-plus",
          "type": "external-provider-source",
          "layer": "server",
          "label": "Codex++ provider source",
          "permissions": ["filesystem.codex-plus-plus.read"]
        }
      ],
      "permissions": [
        {
          "id": "filesystem.codex-plus-plus.read",
          "label": "Read Codex++ local configuration",
          "required": true
        }
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cradle/plugin-sdk": "workspace:*",
    "@types/node": "^22.19.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
