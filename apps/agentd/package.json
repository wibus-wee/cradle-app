{
  "name": "@cradle/agentd",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "cradle-agentd": "./dist/main.mjs"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "node dist/main.mjs",
    "build": "tsdown src/main.ts --format esm --platform node --target node22 --out-dir dist --sourcemap --clean --deps.never-bundle node-pty",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cradle/chat-runtime-contracts": "workspace:*",
    "@cradle/remote-agent-protocol": "workspace:*",
    "@cradle/remote-relay-protocol": "workspace:*",
    "ai": "^6.0.168",
    "node-pty": "1.2.0-beta.13",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
