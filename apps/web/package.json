{
  "name": "@cradle/web",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite --port 5174",
    "build": "pnpm --filter @cradle/plugin-sdk build && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm --filter @cradle/plugin-sdk build && tsc --noEmit && pnpm check:api-boundaries",
    "check:api-boundaries": "tsx scripts/check-api-gen-boundaries.ts",
    "test": "NODE_ENV=test vitest run --config vite.config.ts --environment jsdom src",
    "i18n": "tsx ./scripts/i18n-workflow/index.ts",
    "i18n:diff": "tsx ./scripts/i18n-workflow/gen-diff.ts",
    "i18n:gen-default": "tsx ./scripts/i18n-workflow/gen-default-locale-json.ts",
    "i18n:check-baseline": "tsx ./scripts/i18n-workflow/gen-default-locale-json.ts --check",
    "i18n:check": "tsx ./scripts/i18n-workflow/check-translations.ts",
    "i18n:ci": "pnpm run i18n:check-baseline && pnpm run i18n:check && pnpm run i18n:check-hardcoded",
    "i18n:init-locale": "tsx ./scripts/i18n-workflow/init-locale.ts",
    "i18n:analyze-unused": "tsx ./scripts/i18n-workflow/analyze-unused-keys.ts",
    "i18n:clean-unused": "tsx ./scripts/i18n-workflow/clean-unused-keys.ts",
    "i18n:check-hardcoded": "tsx ./scripts/i18n-workflow/check-hardcoded-text.ts",
    "generate": "pnpm --filter @cradle/server exec vite-node scripts/export-openapi.ts && openapi-ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
