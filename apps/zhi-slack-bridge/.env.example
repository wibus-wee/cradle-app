# Environment variables for zhi-slack-bridge
# Copy this file to .env and fill in the values

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Slack Signing Secret
SLACK_SIGNING_SECRET=

# Unix socket path for MCP communication (optional, defaults to /tmp/zhi-bridge.sock)
ZHI_SOCKET_PATH=/tmp/zhi-bridge.sock

# Data directory for persistence (optional, defaults to ~/.zhi-slack-bridge)
ZHI_DATA_DIR=
