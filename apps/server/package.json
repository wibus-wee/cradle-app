{
  "name": "@cradle/server",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts"
  },
  "main": "src/index.ts",
  "files": [
    "!dist/desktop-plugins/**",
    "!dist/desktop-runtime/**",
    "!dist/node_modules/**",
    "!dist/package.json",
    "dist/**"
  ],
  "scripts": {
    "dev": "nodemon",
    "build": "pnpm --filter @cradle/plugin-sdk build && vite build",
    "build:desktop-plugins": "pnpm --filter \"../../plugins/*\" build && node scripts/prepare-desktop-plugins.mjs",
    "build:desktop-runtime": "pnpm run build && node scripts/prepare-desktop-runtime.mjs && node scripts/rebuild-electron-runtime.mjs",
    "start": "node dist/main.js",
    "generate:codex-app-server-protocol": "node scripts/generate-codex-app-server-protocol.mjs && node scripts/generate-codex-app-server-capabilities.mjs",
    "generate:codex-app-server-capabilities": "node scripts/generate-codex-app-server-capabilities.mjs",
    "tab-working-set:collect": "python3 scripts/tab_working_set_collector.py",
    "leak:harness": "tsx scripts/leak-harness.ts",
    "typecheck": "pnpm --filter @cradle/plugin-sdk build && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/google": "^3.0.72",
    "@ai-sdk/openai": "^3.0.53",
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@cradle/chat-runtime-contracts": "workspace:*",
    "@cradle/db": "workspace:*",
    "@cradle/plugin-sdk": "workspace:*",
    "@elysia/openapi": "^1.4.15",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/node": "^1.4.5",
    "@ff-labs/fff-node": "^0.9.3",
    "@hijarvis/core": "^0.1.0",
    "@hono/node-server": "^1.19.9",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@node-rs/jieba": "^2.0.1",
    "@opencode-ai/sdk": "^1.17.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-prometheus": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/host-metrics": "^0.38.3",
    "@opentelemetry/instrumentation-pino": "^0.64.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.31.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@scalar/hono-api-reference": "^0.10.14",
    "@tsuki-hono/common": "0.0.2",
    "@tsuki-hono/core": "0.0.2",
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^2.2.0",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.10.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "es-module-lexer": "^2.0.0",
    "extract-zip": "^2.0.1",
    "fast-glob": "^3.3.3",
    "format-duration": "^3.0.2",
    "hono": "4.11.9",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.0",
    "node-pty": "1.2.0-beta.13",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "safe-stable-stringify": "2.5.0",
    "sharp": "0.34.5",
    "simple-git": "^3.28.0",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.13",
    "tsyringe": "^4.10.0",
    "undici": "^7.25.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "nodemon": "^3.1.9",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.0",
    "vite-node": "^6.0.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.1.4"
  }
}
