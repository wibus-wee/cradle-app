  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Runtime resources",
      "type": "link",
      "url": "/d/cradle-runtime/cradle-runtime-resources"
    },
    {
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
