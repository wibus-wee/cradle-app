      "title": "Runtime snapshot",
      "type": "link",
      "url": "http://127.0.0.1:21423/observability/runtime-snapshot"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "y": 0,
        "h": 1,
        "x": 0,
        "w": 24
      },
      "id": 1,
      "panels": [],
      "title": "Pressure Flags",
      "type": "row",
      "description": "压力信号分组。这里不判断归属，只把最容易解释内存、流状态、队列状态的信号放到同一段时间轴里。"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "text": "clear"
                },
                "1": {
                  "color": "orange",
                  "text": "active"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "y": 1,
        "h": 7,
        "x": 0,
        "w": 24
      },
      "id": 2,
      "options": {
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_desktop_renderer_memory_bytes{job=~\"$job\", instance=~\"$instance\", kind=\"usedJSHeapSize\"}) > bool 536870912",
          "legendFormat": "renderer heap > 512 MiB",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_desktop_memory_bytes{job=~\"$job\", instance=~\"$instance\", process=\"Tab\", kind=\"working_set\"}) > bool 1073741824",
          "legendFormat": "tab working set > 1 GiB",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_desktop_renderer_chat_store_total{job=~\"$job\", instance=~\"$instance\", kind=\"estimatedPartStringChars\"}) > bool 5000000",
          "legendFormat": "chat payload > 5M chars",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_chat_replay_buffer_chunks{job=~\"$job\", instance=~\"$instance\", runtime_kind=~\"$runtime_kind\"}) > bool 0",
          "legendFormat": "replay buffer retained",
          "range": true,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_observability_queue_depth{job=~\"$job\", instance=~\"$instance\"}) > bool 0",
          "legendFormat": "observability queue backlog",
          "range": true,
          "refId": "E"
        }
      ],
      "title": "Pressure Timeline",
      "type": "state-timeline",
      "description": "布尔压力时间线。active 表示该时间点跨过阈值：renderer heap > 512 MiB、Tab working set > 1 GiB、chat payload > 5M chars、replay buffer retained、observability queue backlog。它用于定位同一时间段有哪些候选原因同时出现。"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "y": 8,
        "h": 8,
        "x": 0,
        "w": 12
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_desktop_memory_bytes{job=~\"$job\", instance=~\"$instance\", process=\"Tab\", kind=\"working_set\"})",
          "legendFormat": "Tab working set",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_desktop_renderer_memory_bytes{job=~\"$job\", instance=~\"$instance\", kind=\"usedJSHeapSize\"})",
          "legendFormat": "Renderer JS heap",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_process_memory_bytes{job=~\"$job\", instance=~\"$instance\", kind=\"rss\"})",
          "legendFormat": "Server RSS",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_pty_rss_bytes{job=~\"$job\", instance=~\"$instance\"})",
          "legendFormat": "PTY RSS",
          "range": true,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_chronicle_daemon_rss_bytes{job=~\"$job\", instance=~\"$instance\"})",
          "legendFormat": "Chronicle RSS",
          "range": true,
          "refId": "E"
        }
      ],
      "title": "Memory Stack",
      "type": "timeseries",
      "description": "内存归因总览。Tab working set 是 Chromium/Electron Tab 进程工作集，包含 JS heap 之外的 native/DOM/layout/canvas/media 等内存；Renderer JS heap 只代表渲染进程 JavaScript 堆；Server/PTY/Chronicle RSS 用来排除其他进程族。"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "y": 8,
        "h": 8,
        "x": 12,
        "w": 12
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum by (kind) (cradle_desktop_renderer_chat_store_total{job=~\"$job\", instance=~\"$instance\", kind=~\"estimatedPartStringChars|messageCount|partCount|textPartCount|toolPartCount|filePartCount\"})",
          "legendFormat": "{{kind}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Renderer Payload Shape",
      "type": "timeseries",
      "description": "渲染端 chat store 的形状。estimatedPartStringChars 近似 retained 字符串体积；messageCount/partCount 反映对象数量；text/tool/file part 的比例用于判断是文本内容、工具调用记录，还是文件 part 在撑大前端状态。"
    },
    {
      "collapsed": false,
      "gridPos": {
        "y": 16,
        "h": 1,
        "x": 0,
        "w": 24
      },
      "id": 5,
      "panels": [],
      "title": "Flow Correlation",
      "type": "row",
      "description": "运行流状态关联。这里看 run、stream、replay、provider host 是否按生命周期同步下降。"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "y": 17,
        "h": 8,
        "x": 0,
        "w": 12
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_chat_active_runs_total{job=~\"$job\", instance=~\"$instance\", runtime_kind=~\"$runtime_kind\"})",
          "legendFormat": "active runs",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(cradle_chat_replay_buffer_chunks{job=~\"$job\", instance=~\"$instance\", runtime_kind=~\"$runtime_kind\"})",
          "legendFormat": "replay chunks",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum by (kind) (cradle_chat_replay_buffer_deltas{job=~\"$job\", instance=~\"$instance\", runtime_kind=~\"$runtime_kind\"})",
          "legendFormat": "replay {{kind}} deltas",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum by (kind) (cradle_desktop_renderer_chat_store_total{job=~\"$job\", instance=~\"$instance\", kind=~\"generatingMessageCount|passiveStreamingMessageCount|activeAbortControllerCount|runDisplayMetaCount|activeGoalCount\"})",
          "legendFormat": "{{kind}}",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "Runs, Streams, Replay",
      "type": "timeseries",
      "description": "把 server active runs、replay buffer、replay delta 类型和 renderer streaming 状态放在一起。任务结束后仍长期非零，通常意味着 stream/replay 状态未释放或前端仍保留可恢复流状态。"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
