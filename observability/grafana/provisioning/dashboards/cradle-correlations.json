          "editorMode": "code",
          "expr": "sum(cradle_provider_runtime_hosts_total{job=~\"$job\", instance=~\"$instance\", runtime_kind=~\"$runtime_kind\"})",
          "legendFormat": "provider hosts",
          "range": true,
