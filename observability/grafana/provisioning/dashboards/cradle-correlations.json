          "editorMode": "code",
          "expr": "sum by (kind) (cradle_provider_runtime_host_state_total{job=~\"$job\", instance=~\"$instance\", runtime_kind=~\"$runtime_kind\"})",
          "legendFormat": "{{kind}}",
          "range": true,
          "refId": "B"
