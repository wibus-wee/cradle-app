{
  "name": "cradle",
  "version": "0.0.1",
  "packageManager": "pnpm@11.2.2",
  "pnpm": {
    "approveBuilds": ["fs-xattr", "macos-alias"]
  },
  "description": "Cradle - AI agent management platform",
  "author": "example.com",
  "bin": {
    "cradle": "./packages/cli/dist/index.js"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "pnpm --filter @cradle/plugin-sdk build && tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:server": "pnpm --filter @cradle/server typecheck",
    "typecheck:apps-web": "pnpm --filter @cradle/web typecheck",
    "typecheck:desktop": "pnpm --filter @cradle/desktop typecheck",
    "typecheck": "npm run typecheck:node && npm run typecheck:server && npm run typecheck:apps-web && npm run typecheck:desktop",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:web": "pnpm --filter @cradle/web dev",
    "dev:server": "pnpm --filter @cradle/server dev",
    "dev:fullstack": "concurrently --names server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:desktop": "pnpm --filter @cradle/desktop dev",
    "observability:up": "docker compose -f observability/docker-compose.yml up -d",
    "observability:down": "docker compose -f observability/docker-compose.yml down",
    "observability:logs": "docker compose -f observability/docker-compose.yml logs -f",
    "build:web": "pnpm --filter @cradle/web build",
    "build:server": "pnpm --filter @cradle/server build",
    "build:desktop": "pnpm --filter @cradle/desktop build",
    "test:server": "pnpm --filter @cradle/server test",
    "generate:web": "pnpm --filter @cradle/web generate",
    "cli": "pnpm --filter @cradle/cli cradle",
    "gen:cli": "pnpm --filter @cradle/cli gen:cli",
    "knip": "knip",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@ai-sdk/openai": "^3.0.53",
    "@base-ui/react": "^1.4.0",
    "@cradle/ipc": "workspace:*",
    "@dnd-kit/dom": "^0.5.0",
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/sn-pro": "^5.2.1",
    "@mingcute/react": "^1.4.1",
    "@node-rs/jieba": "^2.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@pierre/trees": "1.0.0-beta.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/suggestion": "^3.22.4",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "fast-glob": "^3.3.3",
    "fzf": "^0.5.2",
    "geist": "^1.7.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "ignore": "^7.0.5",
    "input-otp": "^1.4.2",
    "js-yaml": "^4.1.1",
    "lowlight": "^3.3.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pathe": "^2.0.3",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "simple-git": "^3.36.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tar": "^7.5.13",
    "tiptap-markdown": "^0.9.0",
    "vaul": "^1.1.2",
    "virtua": "^0.49.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/tar": "^7.0.87",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-hyoban": "^7.0.3",
    "jsdom": "^29.0.2",
    "knip": "^6.13.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-grab": "^0.1.37",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
